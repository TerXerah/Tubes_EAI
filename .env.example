# ================================================================================
# Environment configuration template
# Copy this file to `.env` before running `docker compose up`
# .env is gitignored and must NOT be committed to the repository.
# ================================================================================

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123

# PostgreSQL - POS Service
POS_DB_NAME=pos_db
POS_DB_USER=pos_user
POS_DB_PASS=pos_pass123

# PostgreSQL - CRM Service
CRM_DB_NAME=crm_db
CRM_DB_USER=crm_user
CRM_DB_PASS=crm_pass123

# MySQL - Inventory Service
MYSQL_ROOT_PASSWORD=root_pass123
MYSQL_DB=inventory_db
MYSQL_USER=inventory_user
MYSQL_PASS=inventory_pass123
